CREATE OR REPLACE FUNCTION Bonus(s NUMBER)
RETURN NUMBER
IS
BEGIN
    RETURN s*0.10;
END;
/

DECLARE
    b NUMBER;
BEGIN
    b:=Bonus(50000);
    DBMS_OUTPUT.PUT_LINE('Bonus = '||b);
END;
/

CREATE OR REPLACE PACKAGE DemoPackage AS
    PROCEDURE Hello;
END DemoPackage;
/

CREATE OR REPLACE PACKAGE BODY DemoPackage AS
    PROCEDURE Hello IS
    BEGIN
        DBMS_OUTPUT.PUT_LINE('Package Executed');
    END;
END DemoPackage;
/

BEGIN
    DemoPackage.Hello;
END;
/

